model InstaOsAutomation {
  id         String           @id @default(uuid())
  businessId String
  instagramAccountId String
  name       String           @default("Instagram Comment Automation")
  isActive   Boolean          @default(false)
  postScope  InstaOsPostScope @default(ALL_POSTS)
  version    Int              @default(1)

  Business Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  InstagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  nodes         InstaOsNode[]
  instaOsEvents  InstaOsEvent[]
  instaOsDmOutboxes InstaOsDmOutbox[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([instagramAccountId])
  @@index([businessId, instagramAccountId])
}

/// Paced outbound: DM and/or public comment reply share one QStash flow key per sender IG (`ig.{id}`) — one Graph call per job (Meta ~200/h combined for messages + comment replies).
model InstaOsDmOutbox {
  id     String @id @default(uuid())
  businessId   String
  automationId String
  leadId       String
  /// Instagram comment / trigger id (for sendInstagramDm recipient.comment_id)
  commentId    String
  /// Webhook `parent_id` for thread replies; `POST /replies` must target a top-level id (use this for Graph, not `commentId`).
  publicReplyTargetCommentId String?
  /// Sending business IGSID — use for QStash FlowControl key `ig.{senderInstagramUserId}` (Meta pool is per account).
  senderInstagramUserId String
  /// Rendered DM body; null if automation only posts a public reply.
  messageText  String?  @db.Text
  /// Public comment reply text; null if DM-only.
  replyText     String?  @db.Text
  /// True after `POST /messages` succeeds (or when there is no DM to send).
  dmDelivered  Boolean  @default(false)
  /// True after `POST /{commentId}/replies` succeeds (or when there is no public reply to post).
  commentReplyDelivered Boolean @default(false)
  templateId   String?
  templateName String?
  routingPath  String?
  mediaId         String?
  commentText     String? @db.Text
  senderIgUserId  String?
  senderUsername  String?
  instaOsEventId  String  @unique

  status       InstaOsDmOutboxStatus @default(PENDING)
  attemptCount Int     @default(0)
  lastError    String? @db.Text
  nextRetryAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Lead       Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  automation InstaOsAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  instaOsEvent InstaOsEvent  @relation(fields: [instaOsEventId], references: [id], onDelete: Cascade)

  @@unique([automationId, commentId])
  @@index([status, nextRetryAt])
  @@index([senderInstagramUserId, status])
  @@index([businessId])
  @@index([leadId])
}

model InstaOsNode {
  id           String          @id @default(uuid())
  automationId String
  type         InstaOsNodeType
  sortOrder    Int
  enabled      Boolean         @default(true)
  config       Json

  automation InstaOsAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([automationId, type])
  @@index([automationId])
  @@index([automationId, sortOrder])
}

/// Per-channel: OFF = no message; STATIC = body / replyVariations; AI = LLM (classifier path only; keyword is always static).
enum DmTemplateChannel {
  OFF
  STATIC
  AI
}

model DmTemplate {
  id               String  @id @default(uuid())
  businessId       String
  name             String
  slug             String
  body             String  @db.Text
  // 3–10 comment reply variations when publicChannel=STATIC, validated at application layer.
  replyVariations  Json?
  isPublic         Boolean @default(false)
  category         String?
  tags             Json?
  dmChannel     DmTemplateChannel @default(STATIC)
  publicChannel DmTemplateChannel @default(STATIC)
  aiCommentInstructions String?        @db.Text
  aiDmInstructions      String?        @db.Text

  Business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
}

// ─── Insta OS Enums ──────────────────────────────────────────────────────────

model InstaOsEvent {
  id             String             @id @default(uuid())
  businessId     String
  automationId   String
  leadId         String
  commentId      String             // Instagram comment ID (used for dedup key)
  mediaId        String?            // Post/reel that received the comment
  senderIgUserId String?            // Who commented
  senderUsername String?
  commentText    String             @db.Text
  routingPath    String?            // KEYWORD_MATCH | AI_MATCH | AI_NO_MATCH | NO_RULES
  templateId     String?
  templateName   String?
  status         InstaOsEventStatus @default(PENDING)
  errorMessage   String?            @db.Text
  createdAt      DateTime           @default(now())

  Business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  automation InstaOsAutomation   @relation(fields: [automationId], references: [id], onDelete: Cascade)
  Lead       Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  InstaOsDmOutbox InstaOsDmOutbox?

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([businessId, leadId])
  @@index([automationId])
  @@index([commentId])
  @@index([createdAt])
  @@index([leadId])
}

/// DM outbox — terminal states SENT/FAILED. PENDING = not yet sent via Graph.
enum InstaOsDmOutboxStatus {
  PENDING
  SENT
  FAILED
}

enum InstaOsEventStatus {
  PENDING
  /// Insta OS: DM is queued; Graph send is handled by the DM worker.
  DM_QUEUED
  SENT
  SKIPPED_DEDUP
  ROUTING_FAILED
  ERROR
}

enum InstaOsPostScope {
  ALL_POSTS
  SELECTED_POSTS
}

enum InstaOsNodeType {
  TRIGGER
  KEYWORD_ROUTER
  AI_CLASSIFIER
  // ACTION removed — reply variations now live inside DmTemplate.
  // Templates are the execution unit: they control both the DM body
  // and the comment reply variations. No separate action node needed.
}

enum BaseAgentType {
  STANDARD
  RECALL
  FLOW
}

model BaseAgent {
  id String @id @default(uuid())

  name   String
  description String? @db.Text

  prompt String @db.Text
  tools  Json   @default("[]")

  channel       CHANNEL @default(INSTAGRAM)
  baseAgentType BaseAgentType   @default(STANDARD)

  type    AGENT_TYPE @default(INTEGRATED)

  /// Published FLOW graph (mini-app chat agent). Draft lives in `currentFlow`.
  flow           Json?
  currentFlow    Json?
  flowSettings   Json?
  currentFlowSettings Json?

  /// When false, runtime skips this agent: webhooks/auto-connect/scheduled work treat it as paused.
  /// Mirrors the legacy `Agent.isActive` switch from the AI agent upsert form.
  isActive Boolean @default(true)

  /// At most one auto-connect agent per scoped account when true; enforced in base-agent router.
  autoConnect Boolean @default(false)

  /// When set with autoConnect, this agent auto-attaches only for DMs on this Instagram account.
  instagramAccountId String?
  InstagramAccount   InstagramAccount? @relation("InstagramAccountBaseAgents", fields: [instagramAccountId], references: [id], onDelete: SetNull)

  /// Delivery surface for this base agent (GHL vs native channel APIs).
  provider PROVIDER @default(INSTAGRAM)

  // n8n workflow id
  n8nWorkflowId String?

  /// When set with autoConnect, scopes to this WhatsApp account. Null = all connected accounts.
  whatsAppAccountId String?
  WhatsAppAccount   WhatsAppAccount? @relation("WhatsAppAccountBaseAgents", fields: [whatsAppAccountId], references: [id], onDelete: SetNull)

  businessId String
  Business   Business @relation("BusinessBaseAgents", fields: [businessId], references: [id], onDelete: Cascade)

  agencyId String
  Agency   User   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  recallPrimaryAgentId String?
  RecallPrimaryAgent   PrimaryAgent? @relation("PrimaryAgentBaseAgents", fields: [recallPrimaryAgentId], references: [id], onDelete: SetNull)

  ConversationsWithActiveAgent Conversation[] @relation("ConversationActiveBaseAgent")
  BaseAgentSessions             BaseAgentSession[]
  AgentTools                    AgentTool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([agencyId])
  @@index([recallPrimaryAgentId])
  @@index([businessId, autoConnect])
  @@index([instagramAccountId])
  @@index([whatsAppAccountId])
  @@index([businessId, channel, autoConnect])
}

/// Per-lead FLOW session: DB-backed `currentEvent` (ChatSession analogue for BaseAgent FLOW).
model BaseAgentSession {
  id String @id @default(uuid())

  conversationId String
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  baseAgentId String
  BaseAgent   BaseAgent @relation(fields: [baseAgentId], references: [id], onDelete: Cascade)

  leadId String
  Lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  agencyId String
  Agency   User   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  /// Flow node id (matches JSON `nodes[].id`).
  currentEvent String?

  /// Optional runner scratchpad; canonical IG thread history is `ConversationMessage`.
  messages Json?

  flowEndedAt   DateTime?
  flowEndReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([conversationId, baseAgentId])
  @@index([leadId])
  @@index([businessId])
  @@index([baseAgentId])
  @@index([agencyId])
}

// ─────────────────────────────────────────────────────────────────────────────

model BusinessManager {
  id           String        @id @default(uuid())
  businessId   String
  Business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessRole BUSINESS_ROLE @default(BUSINESS_OWNER)
  managerId    String
  Manager      User          @relation(fields: [managerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([managerId])
}

model BusinessIntegration {
  id String @id @default(uuid())

  businessId String   @unique
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Twilio 
  twilioAccountSid String? @db.Text
  twilioAuthToken  String? @db.Text

  // Twilio Trunk - @todo must be a separate table (with multiple trunks)
  twilioTrunkAuthUsername      String? @db.Text
  twilioTrunkAuthPassword      String? @db.Text
  twilioTrunkTerminationSIPUrl String? @db.Text
  twilioTrunkSIPNumber         String?

  calenderIntegrations CalenderIntegration[]
  n8nIntegrations      N8NIntegration[]

  @@index([businessId])
}

model CalenderIntegration {
  id String @id @default(uuid())

  type CALENDAR_TYPE @default(CAL)

  calEventId  String
  calUsername String
  calApiKey   String

  // Relations
  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  businessIntegrationId String
  BusinessIntegration   BusinessIntegration @relation(fields: [businessIntegrationId], references: [id], onDelete: Cascade)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  PrimaryAgents PrimaryAgent[]

  @@index([businessId])
  @@index([businessIntegrationId])
}

model N8NIntegration {
  id String @id @default(uuid())

  name        String
  description String
  url         String
  token       String

  // Relations
  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  businessIntegrationId String
  BusinessIntegration   BusinessIntegration @relation(fields: [businessIntegrationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([businessIntegrationId])
}

enum RESTACK_SERVICE {
  PRIMARY
  SECONDARY
  TERTIARY
}

// Agentic Layer Tables
model ChatSession {
  id String @id @default(uuid())

  rsRunId   String // restack run id 
  rsAgentId String // restack agent id 

  status       AGENT_SESSION_STATUS @default(ACTIVE)
  statusReason String?              @db.Text // reason for the status change

  /// Which Restack deployment owns this run (standalone stacks; failover = new session + DB replay).
  restackService RESTACK_SERVICE @default(PRIMARY)
  /// Throttles attempts to move a SECONDARY session back to PRIMARY (see PRIMARY_FAILBACK_COOLDOWN_MS).
  lastPrimaryFailbackAttemptAt DateTime?

  messages     Json? // Message[]
  currentEvent String? // current event name

  // Relations
  agencyId String
  Agency   User   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  leadId String
  Lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  primaryAgentId String
  PrimaryAgent   PrimaryAgent @relation(fields: [primaryAgentId], references: [id], onDelete: Cascade)

  agentId String
  Agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // sequence & followup 
  activeSequencePosition Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([leadId])
  @@index([agencyId])
  @@index([primaryAgentId])
  @@index([agentId])
  /// Inbound GHL/chat hot path: find ACTIVE session for lead + channel agent (process-inbound-ghl-message).
  @@index([leadId, agentId, status])
}

model VoiceSession {
  id String @id @default(uuid())

  rsRunId   String? // restack run id (set after agent starts)
  rsAgentId String? // restack agent id

  /// Browser/widget test sessions (no PSTN). Used for LiveKit join + token minting.
  isWebTest        Boolean @default(false)
  livekitRoomName  String?

  /// WhatsApp Business Calling API session id (wacid.*).
  whatsappCallId     String? @unique
  whatsAppAccountId  String?
  voiceChannel       CHANNEL?

  status       VOICE_SESSION_STATUS @default(CALLING)
  statusReason String?              @db.Text
  errorMessage String?              @db.Text

  // Relations
  agencyId String
  Agency   User   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  leadId String
  Lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  primaryAgentId String
  PrimaryAgent   PrimaryAgent @relation(fields: [primaryAgentId], references: [id], onDelete: Cascade)

  agentId String
  Agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  leadCallId String? 
  LeadCall   LeadCall? @relation(fields: [leadCallId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([leadId])
  @@index([agencyId])
  @@index([primaryAgentId])
  @@index([agentId])
  @@index([status])
  @@index([leadCallId])
}

model ChatLog {
  id String @id @default(uuid())

  type    CHAT_LOG_TYPE @default(SUCCESS)
  logType LOG_TYPE      @default(EVENT)

  title       String
  description String? @db.Text // description of the log
  data        Json? // data of the log

  chatAgentId   String?
  chatAgentName String  @default("")

  leadId String
  Lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  endReason     String  @default("")
  chatSessionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([chatAgentId])
  @@index([createdAt])
  @@index([leadId, createdAt])
}

model Automation {
  id String @id @default(uuid())

  name        String
  description String?           @db.Text
  status      AUTOMATION_STATUS @default(DRAFT)

  flow         Json? // react flow json 
  flowSettings Json? // react flow settings json 

  // Relations 
  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  agencyId String
  Agency   User   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  primaryAgentId String
  PrimaryAgent   PrimaryAgent @relation(fields: [primaryAgentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([agencyId])
  @@index([primaryAgentId])
}

model AutomationSession {
  id String @id @default(uuid())

  rsRunId   String // restack run id 
  rsAgentId String // restack agent id 

  status       AGENT_SESSION_STATUS @default(ACTIVE)
  statusReason String?              @db.Text // reason for the status change

  primaryAgentId String
  PrimaryAgent   PrimaryAgent @relation(fields: [primaryAgentId], references: [id], onDelete: Cascade)

  leadId String
  Lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([primaryAgentId])
  @@index([rsAgentId])
  @@index([rsRunId])
}

model Provider {
  id       String   @id @default(uuid())
  provider PROVIDER

  isActive   Boolean @default(true)
  config     Json?
  businessId String

  Business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

// The log for voice call charged to business
model VoiceChargeLog {
  id String @id @default(uuid())

  totalCost  Float
  totalCalls Int

  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([businessId])
}

// The log for message cost charged to business
model MessageChargeLog {
  id String @id @default(uuid())

  totalCost  Float
  totalCalls Int

  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([businessId])
}

model CustomField {
  id         String             @id @default(uuid())
  key        String             @db.VarChar(255)
  label      String             @db.VarChar(255)
  type       String             @default("")
  values     CustomFieldValue[]
  ghlFieldId String?
  source     FIELD_SOURCE       @default(MANUAL)
  businessId String
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  options    Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([businessId, key])
  @@index([businessId])
}

model CustomFieldValue {
  id         String       @id @default(uuid())
  value      String?      @db.Text
  leadId     String
  fieldDefId String
  source     FIELD_SOURCE @default(MANUAL)

  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leadId, fieldDefId])
  @@index([leadId])
  @@index([fieldDefId])
}

model SipTrunk {
  id       String             @id @default(uuid())
  provider SIP_TRUNK_PROVIDER @default(TWILIO)
  status   SIP_TRUNK_STATUS   @default(ACTIVE)

  config Json? // SIP trunk configuration 

  businessId String
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([createdAt])
  @@index([updatedAt])
}

